{
  "enabled": false,
  "home_assistant": {
    "base_url": "http://127.0.0.1:8123",
    "token": "PASTE_LONG_LIVED_ACCESS_TOKEN_HERE"
  },
  "mqtt": {
    "host": "127.0.0.1",
    "port": 1883,
    "username": "",
    "password": "",
    "keepalive": 30
  },
  "webhooks": {
    "turn on bedroom light": {
      "type": "webhook",
      "url": "http://127.0.0.1:9000/webhook/bedroom_light_on",
      "method": "POST",
      "success_message": "Bedroom light turned on."
    },
    "turn off bedroom light": {
      "type": "webhook",
      "url": "http://127.0.0.1:9000/webhook/bedroom_light_off",
      "method": "POST",
      "success_message": "Bedroom light turned off."
    },
    "turn on living room lamp": {
      "type": "home_assistant_service",
      "service": "light.turn_on",
      "entity_id": "light.living_room_lamp",
      "data": {
        "brightness_pct": 80
      },
      "success_message": "Living room lamp turned on."
    },
    "turn off living room lamp": {
      "type": "home_assistant_service",
      "service": "light.turn_off",
      "entity_id": "light.living_room_lamp",
      "success_message": "Living room lamp turned off."
    },
    "turn on desk relay": {
      "type": "mqtt",
      "topic": "home/desk-relay/set",
      "payload": "ON",
      "success_message": "Desk relay turned on."
    },
    "turn off desk relay": {
      "type": "mqtt",
      "topic": "home/desk-relay/set",
      "payload": "OFF",
      "success_message": "Desk relay turned off."
    },
    "unlock front door": {
      "type": "home_assistant_service",
      "service": "lock.unlock",
      "entity_id": "lock.front_door",
      "requires_confirmation": true,
      "risk_level": "high",
      "success_message": "Front door unlocked."
    }
  }
}
