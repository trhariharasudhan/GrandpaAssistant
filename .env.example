LLM_PROVIDER=auto
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini
# Optional backup model for temporary capacity issues
# OPENAI_FALLBACK_MODEL=gpt-4.1-mini
# Optional for compatible providers
# OPENAI_BASE_URL=https://api.openai.com/v1
# Optional retry tuning for rate limits and temporary 5xx provider issues
# OPENAI_MAX_RETRIES=4
# OPENAI_RETRY_BASE_DELAY_SECONDS=2
# OPENAI_RETRY_MAX_DELAY_SECONDS=20
OLLAMA_MODEL=llama3:8b
# OLLAMA_BASE_URL=http://127.0.0.1:11434
